%%%   FRAME NUMBER   %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\defbeamertemplate{frame number block}{minimal}{
	\begin{tikzpicture}[tugtheme]
    \fill[page] (current page.south west) rectangle +(\tugraz@footheight,\tugraz@footheight);
    \draw (current page.south west) +(.5*\tugraz@footheight,.5*\tugraz@footheight) node[anchor=center,font={\usebeamercolor[fg]{page number in head/foot}}] (framenumber) {\insertframenumber};
  \end{tikzpicture}
}

\defbeamertemplate{frame number block}{isec}{
	\begin{tikzpicture}[tugtheme]
    \draw (current page.south west) node[above right] {\isecblock};
    \draw (current page.south west) +(.5*\tugraz@footheight,.4*\tugraz@footheight) node[anchor=center,font={\usebeamercolor[fg]{page number in head/foot}}] (framenumber) {\insertframenumber};
  \end{tikzpicture}
}

\iftugraz@reducedacro
  \setbeamertemplate{frame number block}[isec]
\else
  \setbeamertemplate{frame number block}[minimal]
\fi

%%%   FOOTER   %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\setbeamertemplate{navigation symbols}{}

\defbeamertemplate{footline}{colbar line}{
  \usebeamercolor[bg]{footline}
  \rule{\paperwidth}{\tugraz@footheight cm}
  \usebeamerfont{footline}
  \usebeamertemplate{frame number block}
  \usebeamercolor[fg]{footline}
  \begin{tikzpicture}[tugtheme]
    \draw (current page.south east) +(-\tugraz@indent,.5*\tugraz@footheight) node[left] {\drawadditionallogo};
    \draw (current page.south west) ++(\tugraz@indent,0) coordinate (footindent);
    \draw (footindent|-framenumber.south) node[anchor=base west] {\insertshortauthor\ifx\insertinstitute\empty\else, \insertshortinstitute\fi};
  \end{tikzpicture}
}%

\defbeamertemplate{footline}{reduced}{
  \usebeamertemplate{frame number block}
  \usebeamercolor[fg]{footline}
  \begin{tikzpicture}[tugtheme]
    \draw (current page.south west) ++(\tugraz@indent,0) coordinate (footindent);
    \draw (footindent|-framenumber.south) node[anchor=base west] {\insertshortauthor};
  \end{tikzpicture}
}%

\setbeamertemplate{footline}[colbar line]
\iftugraz@reduced
  \setbeamertemplate{footline}[reduced]
\fi
\iftugraz@reducedacro
  \setbeamertemplate{footline}[reduced]
\fi

\iftugraz@footline
  \newcommand{\unnumbered}[1]{#1}
\else
  \setbeamertemplate{footline}[frame number]

  \newcounter{frameunnumber}
  \newcommand{\unnumbered}[1]{%
    \setcounter{frameunnumber}{\value{framenumber}}
    \setbeamertemplate{footline}[default]
    #1
    \addtocounter{frameunnumber}{-\value{framenumber}}
    \addtocounter{framenumber}{\value{frameunnumber}}
    \setbeamertemplate{footline}[frame number]
  }
\fi

%%%   TITLEPAGE   %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% stretching the claim to the same width as the logo
\RequirePackage{soul}
\iftugraz@webfont
  \sodef\soen{}{0.240em}{1em plus1em}{2em plus.1em minus.1em}
\else
  \sodef\soen{}{0.140em}{1em plus1em}{2em plus.1em minus.1em}
\fi

\newcommand{\tuggreater}{\tikz{\draw[line width=.75pt] (0,0) -- +(.5ex,.5ex) -- +(0,1ex);}}

\newcommand{\tugraz@titlebigsep}{0.75}
\newcommand{\tugraz@titlemedsep}{0.45}

\defbeamertemplate{title page}{presentation}{
  \begin{tikzpicture}[tugtheme]
    \iftugraz@titlepagecolorhead
      % colorhead title page
      \usebeamercolor{welcome page top}
      \iftugraz@titlepagesplithalf
        \draw (current page.north west) ++(0,-4.50) coordinate (titlepageaxis); % 50:50
      \else
        \draw (current page.north west) ++(0,-5.25) coordinate (titlepageaxis); % title lines aligned with half-paperheight / claim bottom / logo baseline
        %\draw (current page.north west) ++(0,-5.56) coordinate (titlepageaxis); % golden ratio, phi:1
      \fi

      \iftugraz@titlepagecolorhead
        \fill[bg] (titlepageaxis) rectangle (current page.north east);
      \fi

      \draw (titlepageaxis) +(\tugraz@indent,\tugraz@indent) coordinate (titleanchor);
    \else
      % plain title page
      \usebeamercolor{title}
      \draw (current page.west) coordinate (titlepageaxis); % 50-50 ratio

      \draw (titlepageaxis) +(\tugraz@indent,0) coordinate (titleanchor); 
    \fi

    % background (logo and claim)
    \iftugraz@logo
      \iftugraz@titlepagecolorhead
        \setbeamercolor{tuglogo}{fg=fg}
      \fi
      \draw (current page.north east) ++(-.4,-.4-.125) node[anchor=north east] {\tuglogoscaled[\tugraz@logosize]};
    \fi

    \iftugraz@claim
    \bgroup
      \usebeamercolor{tuglogo}
      \draw (current page.north east) +(-.4,-1.55)
          node[anchor=north east,align=right,font=\fontsize{7.5}{8.75}\selectfont, fg] {{\soen{SCIENCE}\null}\\{\soen{PASSION}\null}\\{\soen{TECHNOLOGY}\null}};
    \egroup
    \fi

    % title
    \iftugraz@titlepagecolorhead\else
      \usebeamercolor{title}
    \fi
    \ifx\insertsubtitle\empty\else
    \draw (titleanchor) coordinate (subtitleanchor) node[font={\usebeamerfont{subtitle}}, fg] (subtitle) {\parbox[b]{.9\paperwidth}{\raggedright\insertsubtitle}};
    \draw (subtitle.north west) ++(0,18pt) coordinate (titleanchor);
    % 18pt -> same distance between baselines
    % 14pt -> same distance between lines
    \fi

    \iftugraz@webtitle
      \draw (titleanchor) +(2pt,-4pt) coordinate (titlelineanchor) ++(12pt,0) coordinate (titleanchor);
      \usebeamercolor{tuglogo}
    \fi

    \draw (titleanchor) node[font={\usebeamerfont{title}}, fg] (title) {\parbox[b]{.9\paperwidth}{\raggedright\inserttitle}};

    \iftugraz@webtitle
      \draw[bg,line width=3pt] (title.north west-|titlelineanchor) ++(0,3pt) -- (titlelineanchor);
    \fi

    
    \ifx\insertqrcode\empty\else
      \node[anchor=north east] at ($(current page.north east) - (3,0.72)$) {\includegraphics[width=0.21\hsize]{\insertqrcode}};
    \fi

    \usebeamercolor{normal text}

    % contents
    \draw (titlepageaxis) +(\tugraz@indent,-\tugraz@titlebigsep) coordinate (metadataaxis);
    \draw (metadataaxis) node[below right, font={\usebeamercolor[fg]{author}\usebeamerfont{author}}] (author) {\parbox[b]{.9\paperwidth}{\insertauthor}};
    \draw (author.south west) +(0,-\tugraz@titlemedsep) coordinate (metadataaxis);
    \ifx\insertinstitute\empty\else
      \draw (metadataaxis) node[below right, font={\usebeamercolor[fg]{institute}\usebeamerfont{institute}}] (institute) {\parbox[b]{.9\paperwidth}{\insertinstitute}};
      \draw (institute.south west) +(0,-\tugraz@titlemedsep) coordinate (metadataaxis);
    \fi
    \draw (metadataaxis) node[below right, font={\usebeamercolor[fg]{date}\usebeamerfont{date}}] {\parbox[b]{.9\paperwidth}{\insertdate}};


    % footer content
    \draw (current page.south west) +(\tugraz@indent,\tugraz@footheight+.3) node[text width=\tugraz@textwidth,
                                  above right,font=\usebeamerfont{footline}] {\strut\insertlogobar};

    \draw (current page.south west) +(\tugraz@indent,.5*\tugraz@footheight+\tugraz@footlineoffset) node[anchor=base west,font=\usebeamerfont{footline}] {\ifx\insertinstituteurl\empty\else\strut\textcolor{tug}{\tuggreater}~~\insertinstituteurl\fi};
    \draw (current page.south east) +(-\tugraz@indent,0.1) node[above left] {\drawadditionallogo};
	\end{tikzpicture}
}

\setbeamertemplate{title page}[presentation]


