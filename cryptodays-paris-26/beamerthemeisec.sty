%%%   HEADER   %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\defbeamertemplate{headline}{tugurl}{%
  \begin{tikzpicture}[tugtheme]
    \iftugraz@colorhead
      \draw[fill, headline.bg] (current page.north west) rectangle +(\paperwidth,-\tugraz@headcolorheight);
    \fi

    \iftugraz@reducedacro\else
      % URL/logo
      \fill[tug] (current page.north east) ++(-\tugraz@headlinemargin,-\tugraz@headlinemargin) rectangle ++(-1ex,-1ex) coordinate (tmp);
      \draw (tmp) ++(-1ex,0) node[anchor=base east,font={\usebeamerfont{footline}\usebeamercolor[fg]{headline}}] {\insertshortinstituteurl};
    \fi
  \end{tikzpicture}%
}
\setbeamertemplate{headline}[tugurl]
