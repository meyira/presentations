%%%   STANDOUT STYLE   %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\providebool{tugraz@standout}
\define@key{beamerframe}{standout}[true]{%
  \booltrue{tugraz@standout}
  \begingroup
    \setkeys{beamerframe}{c}
    \setkeys{beamerframe}{plain}
    \setkeys{beamerframe}{noframenumbering}
    \centering
    \usebeamerfont{standout}
}
\apptocmd{\beamer@reseteecodes}{%
  \ifbool{tugraz@standout}{
    \endgroup
    \boolfalse{tugraz@standout}
  }{}
}{}{}


\defbeamertemplate{background canvas}{standout}{%
  \ifbeamercolorempty[bg]{standout}{}{\usebeamercolor[bg]{standout}\vrule width\paperwidth height\paperheight}
}
\defbeamertemplate*{background canvas}{empty}{%
  \ifbeamercolorempty[bg]{background canvas}{}{\usebeamercolor[bg]{background canvas}\vrule width\paperwidth height\paperheight}
}

\providebool{tugraz@colorstandout}
\define@key{beamerframe}{colorstandout}[true]{%
  \booltrue{tugraz@colorstandout}
  \begingroup
    \setkeys{beamerframe}{c}
    \setkeys{beamerframe}{plain}
    \setkeys{beamerframe}{noframenumbering}
    \setbeamertemplate{background canvas}[standout]%
    \usebeamercolor[fg]{standout}
    \centering
    \usebeamerfont{standout}
}
\apptocmd{\beamer@reseteecodes}{%
  \ifbool{tugraz@colorstandout}{
    \endgroup
    \setbeamertemplate{background canvas}[empty]%
    \boolfalse{tugraz@colorstandout}
  }{}
}{}{}

